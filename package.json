{
  "name": "hangar-release",
  "version": "0.0.0-managed",
  "private": true,
  "description": "Repo-level release automation (semantic-release): drives CHANGELOG, version bumps, and GitHub releases from Conventional Commits. Not a publishable package.",
  "scripts": {
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^25.0.5"
  }
}
